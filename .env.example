# Copy to .env and fill in. Never commit .env.

# Where the SQLite database lives (inside the container: /data/starbase.db)
DATABASE_PATH=./data/starbase.db

# Public origin for CSRF / form actions (must match Traefik host)
ORIGIN=https://starbase.mcfly.uk

# Random secret, e.g.: openssl rand -base64 32
SESSION_SECRET=change-me

# Token for the wearable sync endpoint (M2+), e.g.: openssl rand -hex 24
SYNC_TOKEN=change-me

# User-Agent for Open Food Facts requests (M2+)
OFF_USER_AGENT=Starbase/1.0 (steve@mcfly.uk)

# Bootstrap the single user on first start (only used when no user exists yet).
# Alternatively run: node scripts/create-user.js <email> <password>
INITIAL_EMAIL=steve@mcfly.uk
INITIAL_PASSWORD=change-me
